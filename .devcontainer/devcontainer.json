{
  "name": "CloudPulse Terraform Env",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform"
      ]
    }
  },
  // Automatically prepare the workspace on launch
  "postCreateCommand": "terraform init -backend=false"
}